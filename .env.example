# =============================================================================
# VSP — Environment Variables
# Copy to .env and fill in. NEVER commit .env.
# =============================================================================

# ----- Core -----
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----- Database -----
DATABASE_URL="postgresql://vsp:vsp@localhost:5432/vsp?schema=public&pgbouncer=true&connection_limit=10"
DATABASE_DIRECT_URL="postgresql://vsp:vsp@localhost:5432/vsp?schema=public"

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- Auth.js -----
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_me_with_32_byte_base64
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
AUTH_COOKIE_DOMAIN=
SESSION_MAX_AGE_SECONDS=2592000        # 30 days
SESSION_IDLE_TIMEOUT_SECONDS=3600      # 1 hour idle = forced re-auth
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200 # 12 hours hard cap

# ----- Internal service-to-service -----
INTERNAL_JWT_SECRET=replace_me_with_32_byte_base64
INTERNAL_JWT_ISSUER=vsp-web
INTERNAL_JWT_AUDIENCE=vsp-api

# ----- Signed URL vendor -----
SIGNING_KEY_CURRENT=replace_me_with_32_byte_base64
SIGNING_KEY_PREVIOUS=
SIGNED_URL_TTL_SECONDS=300             # 5 minutes
DOWNLOAD_URL_TTL_SECONDS=60            # 60 seconds

# ----- Object storage (Cloudflare R2 / S3) -----
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_BUCKET_ORIGINALS=vsp-originals
S3_BUCKET_HLS=vsp-hls
S3_BUCKET_THUMBS=vsp-thumbs
S3_BUCKET_EXPORTS=vsp-exports
S3_FORCE_PATH_STYLE=true

# ----- KMS -----
# Local dev uses an in-memory KEK derived from KMS_LOCAL_MASTER_KEY.
# Production uses AWS KMS via KMS_PROVIDER=aws and KMS_KEY_ID.
KMS_PROVIDER=local                     # local | aws | vault
KMS_LOCAL_MASTER_KEY=replace_me_with_32_byte_base64
KMS_KEY_ID=alias/vsp-master
AWS_REGION=us-east-1

# ----- Mail (Resend) -----
RESEND_API_KEY=
MAIL_FROM="VSP <no-reply@vsp.app>"

# ----- AI (Anthropic Claude) -----
AI_ENABLED=true
AI_PROVIDER=anthropic                  # anthropic | openai | local
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_MONTHLY_TOKEN_CAP=2000000

# ----- Rate limiting -----
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_API_PER_MIN=120
RATE_LIMIT_STREAM_KEY_PER_MIN=60

# ----- Observability -----
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# ----- FFmpeg / Transcode -----
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
TRANSCODE_WORK_DIR=/tmp/vsp-transcode
TRANSCODE_CONCURRENCY=2

# ----- Feature flags (workspace-level overrides in DB) -----
FEATURE_AI_SUMMARY=true
FEATURE_REVIEW_EXPORT=true
FEATURE_SHARE_LINKS=true
FEATURE_DELIVERY_PACKAGES=true
