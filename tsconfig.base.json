{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@vsp/db": ["packages/db/src/index.ts"],
      "@vsp/db/*": ["packages/db/src/*"],
      "@vsp/contracts": ["packages/contracts/src/index.ts"],
      "@vsp/contracts/*": ["packages/contracts/src/*"],
      "@vsp/auth": ["packages/auth/src/index.ts"],
      "@vsp/auth/*": ["packages/auth/src/*"],
      "@vsp/ui": ["packages/ui/src/index.ts"],
      "@vsp/ui/*": ["packages/ui/src/*"],
      "@vsp/crypto": ["packages/crypto/src/index.ts"],
      "@vsp/crypto/*": ["packages/crypto/src/*"],
      "@vsp/config": ["packages/config/src/index.ts"],
      "@vsp/config/*": ["packages/config/src/*"],
      "@vsp/logger": ["packages/logger/src/index.ts"],
      "@vsp/logger/*": ["packages/logger/src/*"],
      "@vsp/player": ["packages/player/src/index.ts"],
      "@vsp/player/*": ["packages/player/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}
