{
  "name": "VSP",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [3000, 4000, 4001, 9000, 9001, 8025, 5432, 6379],
  "portsAttributes": {
    "3000": { "label": "Web (Next.js)", "onAutoForward": "openBrowser" },
    "4000": { "label": "API (NestJS)" },
    "4001": { "label": "Realtime (Socket.io)" },
    "9001": { "label": "MinIO Console" },
    "8025": { "label": "Mailhog UI" }
  },
  "postCreateCommand": "corepack enable && corepack prepare pnpm@9.7.0 --activate && pnpm install && pnpm --filter @vsp/db generate",
  "postStartCommand": "docker compose up -d || true",
  "remoteEnv": {
    "NEXT_PUBLIC_API_URL": "${localEnv:CODESPACE_NAME}-4000.app.github.dev"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
